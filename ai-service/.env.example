# SentinelIQ AI Microservice - Environment Variables Example
# DO NOT place real API keys in this file. Copy this file to '.env' and fill in the actual values.

GROQ_API_KEY=gsk_your_api_key_here
GROQ_MODEL=llama3-70b-8192

# Redis Cache connection (Use 'redis' if running via docker-compose, 'localhost' if running standalone)
REDIS_HOST=localhost
REDIS_PORT=6379